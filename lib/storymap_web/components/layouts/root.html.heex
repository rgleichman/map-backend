<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="user-token" content={@user_token || ""} />
    <.live_title default="Mapgarden">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link phx-track-static rel="icon" href="/images/favicon.ico" />
    <link phx-track-static rel="stylesheet" href="/assets/css/app.css" />
    <script defer phx-track-static type="text/javascript" src="/assets/js/app.js">
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-base-100 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-base-content focus:shadow-lg focus:ring-2 focus:ring-primary focus:outline-none"
    >
      Skip to main content
    </a>
    <div class="drawer h-full">
      <input
        type="checkbox"
        id="drawer-toggle"
        class="drawer-toggle"
        aria-label="Open menu"
      />

      <div class="drawer-content flex flex-col h-full">
        <!-- Navigation bar: brand (all sizes), menu + theme (desktop), theme + hamburger (mobile) -->
        <div class="w-full relative z-50 flex h-14 flex-shrink-0 items-center justify-between gap-3 px-4 sm:px-6 lg:px-8">
          <.link
            navigate={~p"/"}
            class="btn btn-ghost shrink-0 text-lg tracking-tight text-base-content"
          >
            <span class="font-semibold">{gettext("Mapgarden")}</span>
            <span class="font-normal">{" "}{gettext("(beta)")}</span>
          </.link>
          <div class="flex min-w-0 flex-1 items-center justify-end gap-2 sm:gap-3">
            <ul class="menu menu-horizontal hidden min-w-0 flex-1 items-center justify-end gap-1 md:flex lg:gap-2">
              <.nav_menu_items
                variant="desktop"
                current_path={@conn.request_path}
                current_scope={@current_scope}
              />
            </ul>
            <div class="hidden md:block">
              <.theme_toggle variant="compact" />
            </div>
            <label
              for="drawer-toggle"
              class="btn btn-ghost drawer-button shrink-0 md:hidden"
              aria-label="Open menu"
            >
              <span aria-hidden="true"><.icon name="hero-bars-3" class="size-6" /></span>
            </label>
          </div>
        </div>
        
<!-- Page content -->
        <div class={[
          "flex-1 min-h-0",
          unless(full_viewport_map_path?(@conn.request_path), do: "md:pb-24")
        ]}>
          {@inner_content}
        </div>
      </div>
      
<!-- Drawer side menu (mobile) -->
      <div class="drawer-side top-14 h-[calc(100%-3.5rem)] z-50">
        <button
          type="button"
          class="drawer-overlay drawer-close m-0 cursor-pointer border-0 p-0 font-inherit top-14 h-[calc(100%-3.5rem)]"
          aria-label="Close menu"
        >
        </button>
        <ul class="flex flex-col py-4 w-auto min-w-fit max-w-xs min-h-full bg-base-200 text-base-content">
          <.nav_menu_items
            variant="mobile"
            current_path={@conn.request_path}
            current_scope={@current_scope}
          />
          <li class="px-4 pb-3">
            <div class="flex items-center justify-between gap-3">
              <span class="text-sm font-medium text-base-content/70">Theme</span>
              <.theme_toggle variant="compact" />
            </div>
          </li>
        </ul>
      </div>
    </div>
    <.desktop_floating_footer_links current_path={@conn.request_path} />
  </body>
</html>
