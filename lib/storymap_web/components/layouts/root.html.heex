<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="user-token" content={@user_token || ""} />
    <.live_title default="Mapgarden">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link phx-track-static rel="icon" href="/images/favicon.ico" />
    <link phx-track-static rel="stylesheet" href="/assets/css/app.css" />
    <script defer phx-track-static type="text/javascript" src="/assets/js/app.js">
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-base-100 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-base-content focus:shadow-lg focus:ring-2 focus:ring-primary focus:outline-none"
    >
      Skip to main content
    </a>
    <div class="drawer h-full">
      <input
        type="checkbox"
        id="drawer-toggle"
        class="drawer-toggle"
        aria-label="Open menu"
      />

      <div class="drawer-content flex flex-col h-full">
        <!-- Navigation bar with hamburger (mobile) and horizontal menu (desktop) -->
        <div class="w-full flex items-center gap-4 px-4 sm:px-6 lg:px-8 flex-shrink-0">
          <!-- Horizontal menu (desktop only) -->
          <ul class="menu menu-horizontal hidden md:flex items-center gap-4 ml-auto">
            <.nav_menu_items
              variant="desktop"
              current_path={@conn.request_path}
              current_scope={@current_scope}
            />
          </ul>
          
<!-- Hamburger button (mobile only) -->
          <label
            for="drawer-toggle"
            class="btn btn-ghost drawer-button md:hidden ml-auto"
            aria-label="Open menu"
          >
            <span aria-hidden="true"><.icon name="hero-bars-3" class="size-6" /></span>
          </label>
        </div>
        
<!-- Page content -->
        <div class="flex-1 min-h-0">
          {@inner_content}
        </div>
        
<!-- Footer -->
        <footer class="flex-shrink-0 px-4 sm:px-6 lg:px-8 py-4 border-t border-base-300">
          <div class="flex justify-center items-center gap-6 text-sm text-base-content/70">
            <a
              href="https://github.com/rgleichman/map-backend"
              class="hover:text-base-content transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
            <span class="text-base-content/40">•</span>
            <.link
              navigate={~p"/privacy-policy"}
              class="hover:text-base-content transition-colors"
            >
              Privacy Policy
            </.link>
          </div>
        </footer>
      </div>
      
<!-- Drawer side menu (mobile) -->
      <div class="drawer-side">
        <button
          type="button"
          class="drawer-overlay drawer-close m-0 cursor-pointer border-0 p-0 font-inherit"
          aria-label="Close menu"
        >
        </button>
        <ul class="flex flex-col py-4 w-auto min-w-fit max-w-xs min-h-full bg-base-200 text-base-content">
          <.nav_menu_items
            variant="mobile"
            current_path={@conn.request_path}
            current_scope={@current_scope}
          />
        </ul>
      </div>
    </div>
  </body>
</html>
